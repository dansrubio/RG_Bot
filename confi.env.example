# ============================================================
#  REDNITE BOT — Archivo de configuración de ejemplo
#  Copia este archivo como .env y rellena tus valores reales.
#  Nunca subas el archivo .env real a Git.
# ============================================================


# ── BOT PRINCIPAL ────────────────────────────────────────────
# Token del bot obtenido en @BotFather
BOT_TOKEN=

# Nivel de logging: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO


# ── DOCUMENTACIÓN PÚBLICA ────────────────────────────────────
# URLs que se muestran en el mensaje de bienvenida (/start)
BOT_REGLAMENTO_URL=https://example.com/reglamento
BOT_PRIVACIDAD_URL=https://example.com/privacidad

# URL pública del bot (para construir enlaces de elementos)
BOT_URL=https://t.me/tu_bot


# ── PERMISOS DE USUARIOS ─────────────────────────────────────
# IDs de Telegram con acceso total de administración (separados por coma)
ADMIN_IDS=123456789,987654321

# IDs de Telegram con acceso de moderación (separados por coma)
MOD_IDS=111111111,222222222


# ── GRUPOS Y CANALES ─────────────────────────────────────────
# IDs de grupos donde los admins/mods tienen permisos (separados por coma)
# Los IDs negativos de grupos son válidos: -1001234567890
GROUP_ADMIN_ID=-1001234567890

# Grupo principal de administración (supergrupo con topics)
GP_ADMINS=-1001234567890

# Grupo secundario de administración (legacy / respaldo)
ADMINISTRATION_GROUP=-1001234567890

# ID del topic donde llegan las solicitudes de contenido
TOPIC_SOLICITUDES=12

# ID del topic donde llegan los reportes de errores
TOPIC_ERRORES=14

# Canal desde donde se reenvían los archivos de los elementos
CANAL_ELEMENTOS=-1001234567890

# Grupo temporal para operaciones de caché
CACHE_GROUP=-1001234567890

# Canales en los que el usuario debe estar para recibir archivos
# (separados por coma; dejar vacío para desactivar verificación)
BOT_VERIFICATION_CHANNELS=-1001111111111,-1002222222222


# ── BASE DE DATOS MONGODB ────────────────────────────────────
# URI de conexión (Atlas o local)
# Atlas:  mongodb+srv://usuario:password@cluster.mongodb.net/
# Local:  mongodb://localhost:27017
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/

# Nombre de la base de datos
MONGODB_DATABASE=rednite_bot

# (Obsoleto — se mantiene por compatibilidad, preferir MONGODB_URI)
DATABASE_URL=


# ── APIS EXTERNAS ────────────────────────────────────────────
# Rebrandly — acortar URLs con /acortar
# https://app.rebrandly.com/account/api-keys
REBRANDLY_API_KEY=

# Groq AI — generación de fichas de videojuegos
# https://console.groq.com/keys
GROQ_API_KEY=

# TheMovieDB (TMDB) — búsqueda de películas y series
# https://www.themoviedb.org/settings/api
TMDB_ACCESS_TOKEN=
TMDB_API_KEY=

# Steam — búsqueda de videojuegos
# https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# IGDB (Twitch) — base de datos de videojuegos
# https://api-docs.igdb.com/#getting-started
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=


# ── USERBOT TELETHON (indexador) ─────────────────────────────
# Necesario para el comando /index y el autoliker
# Obtén api_id y api_hash en https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Número de teléfono de la cuenta userbot (formato internacional: +34...)
TELEGRAM_PHONE=
